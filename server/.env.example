PORT=5000
# Local Docker: mongodb://admin:expo123@localhost:27017/expoDB?authSource=admin
# Atlas: mongodb+srv://username:password@cluster0.mongodb.net/expoDB
MONGO_URI=mongodb://admin:expo123@localhost:27017/expoDB?authSource=admin
JWT_SECRET=your_super_secret_jwt_key_change_in_production
CLIENT_URL=http://localhost:5173
# Leave CLIENT_URL unset to allow access from any device (e.g. when using --host). Set for production.
# Optional: For forgot password email (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=noreply@eventsphere.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
